# All values are placeholders. Copy to .env.local for local overrides.

# Base URL of the API. In development the Vite proxy handles /api, so this can
# stay as the relative default. Point it at a full URL for other setups.
VITE_API_BASE_URL=/api/v1

# Dev-only: where the Vite proxy forwards /api requests.
VITE_DEV_PROXY_TARGET=http://localhost:8765
